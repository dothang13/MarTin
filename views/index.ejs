<!doctype html>
<html lang="vi">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Muli:wght@400;500;700;800;900&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: { muli: ["Muli", "Arial", "sans-serif"] },
            colors: {
              aoecPink: "#F7838D",
              aoecBlush: "#FF98A1",
              carbon: "#070707",
              graphite: "#151515",
              steel: "#27272a"
            }
          }
        }
      };
      window.__PRINT_MODE__ = <%= printMode ? "true" : "false" %>;
    </script>
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body class="font-muli bg-carbon text-white antialiased <%= printMode ? 'print-route' : '' %>">
    <div class="progress-bar" aria-hidden="true"></div>
    <nav class="deck-nav" aria-label="Điều hướng slide">
      <a href="#hero">01</a>
      <a href="#summary">02</a>
      <a href="#radar">03</a>
      <a href="#funnel">04</a>
      <a href="#phase-awaken">05</a>
      <a href="#phase-thunder">06</a>
      <a href="#phase-glint">07</a>
      <a href="#audience">08</a>
      <a href="#bigidea">09</a>
      <a href="#content">10</a>
      <a href="#kpi">11</a>
      <a href="#timeline">12</a>
      <a href="#closing">13</a>
    </nav>

    <main id="deck">
      <section id="hero" class="slide hero-slide overflow-hidden">
        <div class="slide-deco slide-deco--hero" aria-hidden="true">
          <img src="/img/deco-stars.svg" alt="" class="deco-img deco-img--stars" />
          <img src="/img/deco-wave.svg" alt="" class="deco-img deco-img--wave" />
        </div>
        <div id="particles-js" class="absolute inset-0"></div>
        <div class="forge-grid"></div>
        <img class="martin hero-mascot" src="/assets/martin.png" alt="MarTin mascot" />
        <div class="slide-inner hero-inner">
          <div class="hero-brand-row">
            <img class="hero-brand-logo" src="/assets/easy-chinese-white.png" alt="Easy Chinese AOEC" width="200" height="72" decoding="async" />
          </div>
          <p class="eyebrow">AOEC Marketing Battle 2026</p>
          <p class="hero-campaign-label reveal-up">Chiến dịch IMC · Big Idea</p>
          <h1 class="hero-title split-words">FOMO to PRO</h1>
          <p class="hero-tagline-vn reveal-up">HSK 3.0: Từ áp lực trực tuyến đến thực lực trực diện — biến chứng chỉ thành năng lực nói, dịch và thuyết phục nhà tuyển dụng FDI.</p>
          <p class="hero-copy reveal-up">Đừng để FOMO dẫn dắt, hãy để AOEC giúp bạn dẫn đầu.</p>
          <div class="hero-badges reveal-up">
            <span>Forge The Core</span>
            <span>Micro-size Learning</span>
            <span>Offline Proof</span>
          </div>
        </div>
      </section>

      <section id="summary" class="slide">
        <div class="slide-deco slide-deco--summary" aria-hidden="true">
          <img src="/img/deco-path.svg" alt="" class="deco-img deco-img--path-soft" />
        </div>
        <div class="slide-inner">
          <p class="eyebrow eyebrow-with-icon"><i data-lucide="sparkles" class="lucide-eyebrow" aria-hidden="true"></i> Executive Summary</p>
          <h2 class="section-title reveal-up">Mục tiêu không chỉ là tạo tiếng vang. Mục tiêu là biến chú ý thành lớp học.</h2>
          <div class="summary-grid">
            <article class="glass-card metric-card reveal-card">
              <i data-lucide="radio" class="lucide-card-icon" aria-hidden="true"></i>
              <span class="metric-number" data-count="2000000">0</span>
              <span class="metric-label">Reach toàn chiến dịch</span>
            </article>
            <article class="glass-card metric-card reveal-card">
              <i data-lucide="users-round" class="lucide-card-icon" aria-hidden="true"></i>
              <span class="metric-number" data-count="8000">0</span>
              <span class="metric-label">Leads chất lượng</span>
            </article>
            <article class="glass-card metric-card reveal-card">
              <i data-lucide="badge-check" class="lucide-card-icon" aria-hidden="true"></i>
              <span class="metric-number" data-count="3000">0</span>
              <span class="metric-label">Học viên chuyển đổi</span>
            </article>
          </div>
          <div class="glass-card summary-copy reveal-up">
            <strong class="insight-heading">Insight lõi (tiếng nói học viên):</strong>
            <p class="insight-quote">
              Tôi ám ảnh với việc thua kém bạn bè trên LinkedIn, nhưng tôi càng sợ hơn việc bỏ tiền mua một tấm &ldquo;bằng rỗng&rdquo; để rồi câm nín khi đi phỏng vấn. Tôi cần một bệ phóng khắc nghiệt, &ldquo;ép&rdquo; tôi phải giao tiếp và dịch thuật được ngay lập tức, biến tấm bằng HSK 3.0 thành vũ khí thực chiến giúp tôi tự tin &ldquo;chốt deal&rdquo; với doanh nghiệp FDI.
            </p>
          </div>
        </div>
      </section>

      <section id="radar" class="slide">
        <div class="slide-deco slide-deco--radar" aria-hidden="true">
          <img src="/img/deco-stars.svg" alt="" class="deco-img deco-img--radar-burst" />
        </div>
        <div class="slide-inner radar-layout">
          <div>
            <p class="eyebrow eyebrow-with-icon"><i data-lucide="radar" class="lucide-eyebrow" aria-hidden="true"></i> Competitive Radar</p>
            <h2 class="section-title reveal-up">Bản Đồ Năng Lực Cạnh Tranh Đà Nẵng 2026</h2>
            <p class="body-copy reveal-up">AOEC được đặt ở vùng mạnh nhờ phối hợp EdTech, lớp micro-size, học phí tối ưu, lộ trình HSK 3.0 thực chiến và cơ chế cam kết rõ ràng.</p>
            <p class="chart-legend-hint reveal-up">Chọn <strong>Radar</strong> để so khối toàn diện, hoặc <strong>Cột so sánh</strong> để đọc điểm từng tiêu chí. Nhấn từng thương hiệu để ẩn/hiện trên đồ thị.</p>
          </div>
          <div class="compete-panel reveal-card">
            <div class="chart-toolbar" role="tablist" aria-label="Kiểu biểu đồ">
              <button type="button" class="chart-tab is-active" data-chart-mode="radar" role="tab" aria-selected="true">Radar</button>
              <button type="button" class="chart-tab" data-chart-mode="bar" role="tab" aria-selected="false">Cột so sánh</button>
            </div>
            <div class="chart-canvas-stack">
              <div class="chart-view is-active" data-chart-view="radar">
                <canvas id="competitorRadar" aria-label="Biểu đồ radar so sánh AOEC với đối thủ"></canvas>
              </div>
              <div class="chart-view" data-chart-view="bar" hidden>
                <canvas id="competitorBar" aria-label="Biểu đồ cột so sánh điểm theo tiêu chí"></canvas>
              </div>
            </div>
            <div class="dataset-toggles" id="datasetToggles" aria-label="Bật tắt từng đối thủ"></div>
          </div>
        </div>
      </section>

      <section id="funnel" class="slide">
        <div class="slide-inner">
          <p class="eyebrow eyebrow-with-icon"><i data-lucide="rocket" class="lucide-eyebrow" aria-hidden="true"></i> Growth Hacking Funnel</p>
          <h2 class="section-title reveal-up">Ba nhịp tăng trưởng — từ cảnh tỉnh đến chốt sales.</h2>
          <p class="body-copy reveal-up">Đúng lộ trình IMC trong đề bài: <strong>Awaken</strong> giáng đòn “bằng rỗng”, <strong>Thunder</strong> thu lead bằng gamification &amp; AI, <strong>Glint</strong> chốt bằng cam kết thép và minh chứng offline.</p>
          <div class="funnel-pipeline">
            <article class="pipeline-card tilt-card reveal-card" data-tilt>
              <span class="pipeline-step">Nhịp 01</span>
              <h3 class="pipeline-title"><i data-lucide="sunrise" class="lucide-inline" aria-hidden="true"></i> Awaken</h3>
              <p>Đánh thức FOMO &amp; LinkedIn envy; OOH + phim ngắn cảnh tỉnh về học vẹt / chứng chỉ không dùng được.</p>
              <a class="pipeline-link" href="#phase-awaken">Chi tiết →</a>
            </article>
            <span class="pipeline-arrow" aria-hidden="true"></span>
            <article class="pipeline-card tilt-card reveal-card" data-tilt>
              <span class="pipeline-step">Nhịp 02</span>
              <h3 class="pipeline-title"><i data-lucide="zap" class="lucide-inline" aria-hidden="true"></i> Thunder</h3>
              <p>Thu thập lead chất lượng: thử thách, quiz AI, livestream clinic — chi phí tiệm cận 0 đồng / lead.</p>
              <a class="pipeline-link" href="#phase-thunder">Chi tiết →</a>
            </article>
            <span class="pipeline-arrow" aria-hidden="true"></span>
            <article class="pipeline-card tilt-card reveal-card" data-tilt>
              <span class="pipeline-step">Nhịp 03</span>
              <h3 class="pipeline-title"><i data-lucide="gem" class="lucide-inline" aria-hidden="true"></i> Glint</h3>
              <p>Chuyển đổi: open class, “hợp đồng thép” đảo ngược rủi ro, counselor chốt lớp theo nhóm.</p>
              <a class="pipeline-link" href="#phase-glint">Chi tiết →</a>
            </article>
          </div>
        </div>
      </section>

      <section id="phase-awaken" class="slide phase-detail-slide">
        <div class="slide-inner phase-detail-inner">
          <p class="eyebrow">Nhịp 01 · Awaken</p>
          <h2 class="section-title reveal-up">Cảnh tỉnh: FOMO không đủ, cần thấy rủi ro “bằng rỗng”.</h2>
          <div class="phase-detail-grid">
            <div class="phase-detail-block reveal-card">
              <h3>Mục tiêu</h3>
              <ul>
                <li>Nhận diện nỗi sợ thua trên LinkedIn / MXH và nỗi sợ đầu tư chứng chỉ vô dụng khi phỏng vấn.</li>
                <li>Dựng frame: HSK 3.0 bắt buộc Nói + Dịch — học vẹt = điểm rơi thực tế.</li>
              </ul>
            </div>
            <div class="phase-detail-block reveal-card">
              <h3>Kênh &amp; chạm</h3>
              <ul>
                <li>OOH (MarTin xuống phố), phim ngắn drama học đường / đi phỏng vấn.</li>
                <li>Short video, meme học thuật, quiz “bạn đang tụt bao nhiêu level?”</li>
              </ul>
            </div>
            <div class="phase-detail-block reveal-card">
              <h3>Chỉ số &amp; hook</h3>
              <ul>
                <li>Reach, completion video, lượt làm quiz.</li>
                <li><strong>Hook:</strong> “Bạn đang tụt bao nhiêu level?” — dẫn về lời giải AOEC.</li>
              </ul>
            </div>
          </div>
        </div>
      </section>

      <section id="phase-thunder" class="slide phase-detail-slide">
        <div class="slide-inner phase-detail-inner">
          <p class="eyebrow">Nhịp 02 · Thunder</p>
          <h2 class="section-title reveal-up">Kích hoạt: lead phải “chơi” tiếng Trung, không chỉ xem.</h2>
          <div class="phase-detail-grid">
            <div class="phase-detail-block reveal-card">
              <h3>Mục tiêu</h3>
              <ul>
                <li>Thu <strong>8.000 leads</strong> chất lượng với chi phí / lead thấp nhờ gamification &amp; AI.</li>
                <li>Ép lộ lỗ hổng nghe — nói — dịch để tư vấn có dữ liệu.</li>
              </ul>
            </div>
            <div class="phase-detail-block reveal-card">
              <h3>Kênh &amp; chạm</h3>
              <ul>
                <li>Thử thách 7 ngày, leaderboard, voucher học thử.</li>
                <li>Livestream clinic sửa phát âm, mini-test sau mỗi buổi, retargeting theo hành vi quiz.</li>
              </ul>
            </div>
            <div class="phase-detail-block reveal-card">
              <h3>Chỉ số &amp; hook</h3>
              <ul>
                <li>Tỷ lệ hoàn thành thử thách, CPL, số booking học thử.</li>
                <li><strong>Hook:</strong> “7 ngày thoát học vẹt.”</li>
              </ul>
            </div>
          </div>
        </div>
      </section>

      <section id="phase-glint" class="slide phase-detail-slide">
        <div class="slide-inner phase-detail-inner">
          <p class="eyebrow">Nhịp 03 · Glint</p>
          <h2 class="section-title reveal-up">Chốt niềm tin: thấy lớp, thấy tiến bộ, thấy văn bản cam kết.</h2>
          <div class="phase-detail-grid">
            <div class="phase-detail-block reveal-card">
              <h3>Mục tiêu</h3>
              <ul>
                <li>Chuyển lead thành <strong>3.000 học viên</strong> qua minh chứng trực diện và giảm rủi ro cảm nhận.</li>
                <li>Biến “đã thử” thành “đã ký” bằng social proof và điều khoản rõ ràng.</li>
              </ul>
            </div>
            <div class="phase-detail-block reveal-card">
              <h3>Kênh &amp; chạm</h3>
              <ul>
                <li>Open class offline, review thật từ học viên, counselor theo nhóm bạn học.</li>
                <li>“Hợp đồng thép” / chính sách đảo ngược rủi ro (cam kết đầu ra, quy trình hoàn học phí minh bạch).</li>
              </ul>
            </div>
            <div class="phase-detail-block reveal-card">
              <h3>Chỉ số &amp; hook</h3>
              <ul>
                <li>Trial attendance, tỷ lệ deposit, NPS sau buổi đầu.</li>
                <li><strong>Hook:</strong> “Đến lớp là thấy mình tiến bộ.”</li>
              </ul>
            </div>
          </div>
        </div>
      </section>

      <section id="audience" class="slide audience-slide">
        <div class="slide-inner two-col">
          <div>
            <p class="eyebrow">Audience Tension</p>
            <h2 class="section-title reveal-up">Từ áp lực trực tuyến đến hành động trực diện.</h2>
            <p class="body-copy reveal-up">Chiến dịch không phủ nhận FOMO. Nó chuyển hóa FOMO thành một lời mời có cấu trúc: kiểm tra hiện trạng, luyện một kỹ năng nhỏ, nhận phản hồi ngay, rồi bước vào lớp thật.</p>
          </div>
          <div class="tension-stack">
            <div class="tension-item reveal-card"><span class="tension-label"><i data-lucide="flame" class="lucide-tension" aria-hidden="true"></i> FOMO</span><p>Sợ thua bạn bè, chậm chứng chỉ, mất cơ hội.</p></div>
            <div class="tension-item reveal-card"><span class="tension-label"><i data-lucide="shield-off" class="lucide-tension" aria-hidden="true"></i> Friction</span><p>Sợ lớp đông, ngại phát âm, học online dễ bỏ cuộc.</p></div>
            <div class="tension-item reveal-card"><span class="tension-label"><i data-lucide="eye" class="lucide-tension" aria-hidden="true"></i> Proof</span><p>Muốn thấy tiến bộ cụ thể trước khi đóng học phí.</p></div>
          </div>
        </div>
      </section>

      <section id="bigidea" class="slide">
        <div class="slide-deco slide-deco--bigidea" aria-hidden="true">
          <img src="/img/deco-wave.svg" alt="" class="deco-img deco-img--wave-soft" />
        </div>
        <div class="slide-inner big-idea">
          <p class="eyebrow eyebrow-with-icon"><i data-lucide="lightbulb" class="lucide-eyebrow" aria-hidden="true"></i> Tái định vị thương hiệu &amp; Big Idea</p>
          <p class="big-idea-label reveal-up">BIG IDEA</p>
          <h2 class="fomo-pro-headline reveal-up">FOMO to PRO</h2>
          <p class="big-idea-vn-explain reveal-up">
            <span class="vn-explain-lead">Ý nghĩa bằng tiếng Việt:</span>
            <strong>HSK 3.0: Từ áp lực trực tuyến đến thực lực trực diện</strong>
            — không còn học vì sợ tụt hậu trên mạng, mà luyện để thể hiện được ngay trước nhà tuyển dụng và doanh nghiệp FDI.
          </p>
          <p class="key-message reveal-up"><strong>KEY MESSAGE:</strong> Đừng để FOMO dẫn dắt, hãy để AOEC giúp bạn dẫn đầu.</p>
          <blockquote class="key-message-quote reveal-up">
            Thay vì để nỗi sợ khiến bạn học trong mù quáng, hãy để AOEC biến việc học thành lợi thế cạnh tranh bằng một tấm bằng thực chất.
          </blockquote>
          <div class="idea-strip">
            <span>LinkedIn Envy</span>
            <span>Sợ bằng rỗng</span>
            <span>Luyện nói &amp; dịch</span>
            <span>Thực chiến FDI</span>
          </div>
        </div>
      </section>

      <section id="content" class="slide">
        <div class="slide-inner">
          <p class="eyebrow">Content Engine</p>
          <h2 class="section-title reveal-up">Nội dung được thiết kế như một đường ray chuyển đổi.</h2>
          <div class="content-grid">
            <article class="content-card reveal-card"><h3 class="content-card-title"><i data-lucide="clapperboard" class="lucide-inline" aria-hidden="true"></i> Reels/TikTok</h3><p>POV đi thi HSK, lỗi phát âm phổ biến, “một câu nói cứu buổi phỏng vấn”.</p></article>
            <article class="content-card reveal-card"><h3 class="content-card-title"><i data-lucide="clipboard-list" class="lucide-inline" aria-hidden="true"></i> Quiz Lead Magnet</h3><p>Test 90 giây xác định lỗ hổng: nghe, đọc, khẩu ngữ, ngữ pháp.</p></article>
            <article class="content-card reveal-card"><h3 class="content-card-title"><i data-lucide="mic-2" class="lucide-inline" aria-hidden="true"></i> Livestream Clinic</h3><p>Giảng viên sửa lỗi thật, MarTin làm mascot dẫn dắt thử thách.</p></article>
            <article class="content-card reveal-card"><h3 class="content-card-title"><i data-lucide="school" class="lucide-inline" aria-hidden="true"></i> Offline Trial</h3><p>Buổi học nhỏ, có mini report sau lớp và voucher đăng ký nhanh.</p></article>
          </div>
        </div>
      </section>

      <section id="kpi" class="slide">
        <div class="slide-inner kpi-layout">
          <div>
            <p class="eyebrow">Measurement</p>
            <h2 class="section-title reveal-up">Mỗi giai đoạn có một chỉ số thắng riêng.</h2>
          </div>
          <div class="bar-chart reveal-card">
            <div><span>Awaken Reach</span><i style="--w:92%"></i><b>2M</b></div>
            <div><span>Quiz Completion</span><i style="--w:72%"></i><b>45%</b></div>
            <div><span>Lead Quality</span><i style="--w:80%"></i><b>8K</b></div>
            <div><span>Trial Attendance</span><i style="--w:64%"></i><b>1.2K</b></div>
            <div><span>Enrollment</span><i style="--w:86%"></i><b>3K</b></div>
          </div>
        </div>
      </section>

      <section id="timeline" class="slide">
        <div class="slide-inner">
          <p class="eyebrow">Rollout Timeline</p>
          <h2 class="section-title reveal-up">8 tuần đi từ tiếng vang đến doanh thu lớp học.</h2>
          <div class="timeline">
            <div class="timeline-node reveal-card"><b>W1-W2</b><span>Tease FOMO score, KOL seeding, landing quiz.</span></div>
            <div class="timeline-node reveal-card"><b>W3-W5</b><span>Challenge 7 ngày, livestream clinic, retargeting.</span></div>
            <div class="timeline-node reveal-card"><b>W6-W7</b><span>Offline open class, referral squad, counselor follow-up.</span></div>
            <div class="timeline-node reveal-card"><b>W8</b><span>Showcase kết quả, chốt lớp, publish proof pack.</span></div>
          </div>
        </div>
      </section>

      <section id="closing" class="slide closing-slide">
        <div class="slide-deco slide-deco--closing" aria-hidden="true">
          <img src="/img/deco-stars.svg" alt="" class="deco-img deco-img--closing-stars" />
          <img src="/img/deco-path.svg" alt="" class="deco-img deco-img--closing-path" />
        </div>
        <div class="forge-grid"></div>
        <img class="martin closing-mascot" src="/assets/martin.png" alt="MarTin mascot" />
        <div class="slide-inner closing-inner">
          <div class="closing-brand-row">
            <img class="closing-brand-logo" src="/assets/easy-chinese-white.png" alt="Easy Chinese AOEC" width="260" height="90" decoding="async" />
          </div>
          <p class="eyebrow eyebrow-with-icon"><i data-lucide="party-popper" class="lucide-eyebrow" aria-hidden="true"></i> The Close</p>
          <h2 class="closing-title split-words">FOMO kéo họ dừng lại. PRO khiến họ đăng ký.</h2>
